{
  "name": "oc-pi-cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "types:check": "tsc --noEmit",
    "workbench:smoke:sessions": "bun run tests/regression/check-workbench-session-smoke.ts",
    "goal-to-docs:check:preview:stable": "bun run tests/regression/check-goal-to-docs-fixtures.ts preview-stable",
    "goal-to-docs:check:preview:adversarial": "bun run tests/regression/check-goal-to-docs-fixtures.ts preview-adversarial",
    "goal-to-docs:check:preview": "bun run tests/regression/check-goal-to-docs-fixtures.ts preview",
    "goal-to-docs:check:sandbox:stable": "bun run tests/regression/check-goal-to-docs-fixtures.ts sandbox-stable",
    "goal-to-docs:check:sandbox": "bun run tests/regression/check-goal-to-docs-fixtures.ts sandbox",
    "goal-to-docs:check": "bun run types:check && bun run goal-to-docs:check:preview && bun run goal-to-docs:check:sandbox"
  },
  "dependencies": {
    "undici": "8.2.0",
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "^24.10.2",
    "typescript": "6.0.2"
  }
}
